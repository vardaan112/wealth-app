DATABASE_URL=postgres://wealth_user:wealth_password@localhost:5432/wealth_app
PORT=8000
JWT_SECRET=change-this-long-random-secret
APP_USER_EMAIL=you@example.com
APP_USER_PASSWORD=change-this-password
APP_ENCRYPTION_KEY=base64-encoded-32-byte-key
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox
# Required for OAuth banks (e.g. Chase). Must be registered in the Plaid
# Dashboard under Allowed redirect URIs. Defaults to this value if unset.
PLAID_REDIRECT_URI=http://localhost:5173/plaid-oauth
SNAPTRADE_CLIENT_ID=your-snaptrade-client-id
SNAPTRADE_CONSUMER_KEY=your-snaptrade-consumer-key
# Personal (PERS-) API keys authenticate with just the client id + consumer key
# (signed requests); SnapTrade resolves the account owner from the key, so no
# userId/userSecret and no registerUser call are needed.
